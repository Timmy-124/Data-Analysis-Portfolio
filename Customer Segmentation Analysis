--- This analysis is focused on identifying customer segments based on purchase frequency, spending patterns, product preferences, and promotional behavior

--- This data is a sample data generated by ChatGPT

--- Total Revenue
SELECT SUM(totalamount) AS total_revenue
FROM veloura_customer_data;

--- Average Order Value
SELECT AVG(totalamount) AS average_order_value
FROM veloura_customer_data;

--- Customer Lifetime Value (CLV)
SELECT customerid,
       SUM(totalamount) AS customer_lifetime_value
FROM veloura_customer_data
GROUP BY customerid
ORDER BY customer_lifetime_value DESC;

--- What are the Customer Segments?
WITH customer_summary AS (

SELECT
    CustomerID,

    COUNT(TransactionID) AS Total_Orders,

    SUM(TotalAmount) AS Total_Spending,

    AVG(TotalAmount) AS Avg_Order_Value,

    SUM(
        CASE 
            WHEN PromotionApplied = 1 THEN 1
            ELSE 0
        END
    ) AS Promo_Purchases,

    MIN(Date) AS First_Purchase_Date,

    MAX(Date) AS Last_Purchase_Date

FROM veloura_customer_data

GROUP BY CustomerID
)

SELECT
    CustomerID,
    Total_Orders,
    ROUND(Total_Spending,2) AS Total_Spending,
    ROUND(Avg_Order_Value,2) AS Avg_Order_Value,
    Promo_Purchases,
    First_Purchase_Date,
    Last_Purchase_Date,

CASE

    /* High spending + frequent purchases */
    WHEN Total_Spending >= 250
         AND Total_Orders >= 8
    THEN 'Premium Loyalists'

    /* Frequent purchases but lower spending */
    WHEN Total_Orders >= 8
         AND Total_Spending < 250
    THEN 'Frequent Snack Buyers'

    /* Customers mainly purchasing during promotions */
    WHEN Promo_Purchases >= Total_Orders * 0.6
    THEN 'Discount-Driven Customers'

    /* Customers with low purchase frequency */
    WHEN Total_Orders BETWEEN 3 AND 7
    THEN 'Occasional Buyers'

    /* Very recent or low activity customers */
    WHEN Total_Orders <= 2
    THEN 'New Customers'

    ELSE 'Regular Customers'

END AS Customer_Segment

FROM customer_summary
ORDER BY Total_Spending DESC;

--- What is the Product Preference For Each Customer Segment?

WITH customer_summary AS (

SELECT
    CustomerID,

    COUNT(TransactionID) AS Purchase_Frequency,

    SUM(TotalAmount) AS Total_Spending,

    SUM(
        CASE
            WHEN PromotionApplied = 1 THEN 1
            ELSE 0
        END
    ) AS Promo_Purchases

FROM veloura_customer_data

GROUP BY CustomerID
),

customer_segments AS (

SELECT
    CustomerID,

CASE

    WHEN Total_Spending >= 50
         AND Purchase_Frequency >= 8
    THEN 'Premium Loyalists'

    WHEN Purchase_Frequency >= 8
         AND Total_Spending < 50
    THEN 'Frequent Snack Buyers'

    WHEN Promo_Purchases >= Purchase_Frequency * 0.6
    THEN 'Discount-Driven Customers'

    WHEN Purchase_Frequency BETWEEN 3 AND 7
    THEN 'Occasional Buyers'

    WHEN Purchase_Frequency <= 2
    THEN 'New Customers'

END AS Customer_Segment

FROM customer_summary
),

product_frequency AS (

SELECT
    cs.Customer_Segment,
    v.Product,

    COUNT(v.TransactionID) AS Purchase_Count,

    RANK() OVER(
        PARTITION BY cs.Customer_Segment
        ORDER BY COUNT(v.TransactionID) DESC
    ) AS product_rank

FROM veloura_customer_data v

JOIN customer_segments cs
    ON v.CustomerID = cs.CustomerID

GROUP BY
    cs.Customer_Segment,
    v.Product
)

SELECT
    Customer_Segment,
    Product,
    Purchase_Count

FROM product_frequency

WHERE product_rank = 1
ORDER BY Purchase_Count DESC;

